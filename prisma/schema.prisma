// Prisma Schema for mailturtle - Email Intelligence App
// Database: PostgreSQL
// Learn more: https://pris.ly/d/prisma-schema

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// ========== USER & LOGIN ==========

model User {
  id                String                   @id @default(cuid())
  email             String                   @unique
  name              String?
  passwordHash      String?
  googleId          String?                  @unique
  googleAccessToken String?
  picture           String?
  lastLoginAt       DateTime?
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  emails            Email[]
  rules             CustomRule[]
  preferences       UserPreference?
  aiInteractions    AIInteraction[]
  activities        UserActivity[]
  quotas            UserQuota[]

  @@index([email])
}

model UserPreference {
  id                    String    @id @default(cuid())
  userId                String    @unique
  autoAnalyze           Boolean   @default(true)
  theme                 String    @default("light")
  onboardingCompleted   Boolean   @default(false)
  hasUsedAiBefore       String?
  focusAreas            String[]  @default([])
  assistantStyle        String?
  notificationEnabled   Boolean   @default(true)
  notificationFrequency String?
  lastDigestSentAt      DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ========== EMAILS ==========

model Email {
  id         String                   @id @default(cuid())
  userId     String
  gmailId    String?                  @unique
  gmailLabel String?                  @default("inbox")
  subject    String
  from       String
  to         String
  cc         String?
  preview    String?
  body       String?
  receivedAt DateTime
  analyzedAt DateTime?
  sentiment  String?
  importance String                   @default("NORMAL")
  isRead     Boolean                  @default(false)
  isSpam     Boolean                  @default(false)
  isFlagged  Boolean                  @default(false)
  summary    String?
  shouldNotify Boolean                @default(false)
  matchReason String?
  keyPoints  String?
  createdAt  DateTime                 @default(now())
  updatedAt  DateTime                 @updatedAt

  user       User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category   EmailCategoryRecord?
  aiLogs     AIInteraction[]

  @@index([userId])
  @@index([gmailId])
  @@index([gmailLabel])
  @@index([isRead])
  @@index([isSpam])
}

model EmailCategoryRecord {
  id            String   @id @default(cuid())
  emailId        String   @unique
  category       String
  confidence     Float    @default(0.5)
  aiModel        String
  userConfirmed  Boolean  @default(false)
  createdAt      DateTime @default(now())

  email          Email    @relation(fields: [emailId], references: [id], onDelete: Cascade)

  @@index([emailId])
  @@index([category])
}

// ========== CUSTOM RULES ==========

model CustomRule {
  id             String   @id @default(cuid())
  userId         String
  name           String
  enabled        Boolean  @default(true)
  priority       Int      @default(0)
  
  // Legacy fields (kept for backward compatibility)
  isActive       Boolean  @default(true)
  ruleType       String?
  condition      String?
  targetCategory String?
  
  // New flexible format
  conditions     Json     @default("{}")  // { senders: [], subjects: [], keywords: [] }
  actions        Json     @default("{}")  // { category, notify, star, labels }
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, enabled])
  @@index([isActive])
}

// ========== AI TRACKING ==========

model AIInteraction {
  id            String   @id @default(cuid())
  userId        String
  emailId       String?
  action        String
  tokensUsed    Int      @default(0)
  estimatedCost Float    @default(0)
  responseTime  Int?
  success       Boolean  @default(true)
  errorMessage  String?
  createdAt     DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  email         Email?   @relation(fields: [emailId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([emailId])
  @@index([createdAt])
}



// ========== USAGE TRACKING ==========

model UserActivity {
  id             String   @id @default(cuid())
  userId         String
  date           DateTime @db.Date
  emailsAnalyzed Int      @default(0)
  aiCallsMade    Int      @default(0)
  tokenUsed      Int      @default(0)
  createdAt      DateTime @default(now())

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@unique([userId, date])
}

model UserQuota {
  id         String   @id @default(cuid())
  userId     String
  month      String
  callsUsed  Int      @default(0)
  callsLimit Int      @default(10000)
  costUsed   Float    @default(0)
  costLimit  Float    @default(100)
  resetAt    DateTime
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@unique([userId, month])
}
